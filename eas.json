      },
      "android": {
        "autoIncrement": true,
        "buildType": "apk"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6759897149",
        "appleId": "dev@guardian.space",
        "appleTeamId": "6WWZ5MC87D"
      }
    }
  }
